@{
    ViewData["Title"] = "Upload Menu";
}

<h2>Upload Menu Images</h2>

<input type="file" id="fileInput" multiple />
<button onclick="uploadFiles()">Upload</button>

<div id="progressContainer"></div>

@if (ViewBag.Message != null)
{
    <p>@ViewBag.Message</p>
}

<script>
    async function uploadFiles() {
        const files = document.getElementById("fileInput").files;
        const container = document.getElementById("progressContainer");
        container.innerHTML = "";

        for (let i = 0; i < files.length; i++) {
            const file = files[i];

            // Create UI block
            const wrapper = document.createElement("div");
            wrapper.innerHTML = `
                <p>${file.name}</p>
                <progress value="0" max="100" id="progress-${i}"></progress>
                <span id="status-${i}">Uploading...</span>
            `;
            container.appendChild(wrapper);

            const formData = new FormData();
            formData.append("files", file);

            const xhr = new XMLHttpRequest();
            xhr.open("POST", "/Menu/Upload", true);

            // Progress tracking
            xhr.upload.onprogress = function (e) {
                if (e.lengthComputable) {
                    const percent = (e.loaded / e.total) * 100;
                    document.getElementById(`progress-${i}`).value = percent;
                }
            };

            // Success
            xhr.onload = function () {
                if (xhr.status === 200) {
                    document.getElementById(`progress-${i}`).value = 100;
                    document.getElementById(`status-${i}`).innerText = "Completed ✅";
                    document.getElementById(`status-${i}`).style.color = "green";
                } else {
                    document.getElementById(`status-${i}`).innerText = "Failed ❌";
                    document.getElementById(`status-${i}`).style.color = "red";
                }
            };

            // Network error
            xhr.onerror = function () {
                document.getElementById(`status-${i}`).innerText = "Failed ❌";
                document.getElementById(`status-${i}`).style.color = "red";
            };

            xhr.send(formData);
        }
    }
</script>